BUN_DEV=development

FRONTEND_URL=http://localhost:5173
JWT_SECRET=your-jwt-secret-here

REDIS_PASSWORD=your_redis_password
# Same value must appear after redis://: in REDIS_URL.
# docker-compose.redis.yml reads this file; full docker-compose.yml may also need
# REDIS_PASSWORD in a repo-root .env for Compose variable substitution on the redis service.
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379


TURSO_DB_URL=
TURSO_DB_TOKEN=
